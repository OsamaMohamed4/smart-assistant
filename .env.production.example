# Smart Assistant — production environment (Railway Variables)
# Anything marked REQUIRED must be set or the process refuses to boot
# (lib/secrets.js). See README.md for the full table.

# ─── Node / Express ────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
# Proxy hops in front of Node. Railway always has exactly one. A wrong value
# lets clients spoof X-Forwarded-For and bypass rate limiting + login lockout.
TRUST_PROXY=1
# Enables the __Host- session cookie (origin-locked, Secure, Path=/).
COOKIE_SECURE=true

# ─── Database ──────────────────────────────────────────────────────
# REQUIRED. Production runs PostgreSQL; SQLite is dev only.
DB_DRIVER=postgres
DATABASE_URL=postgres://user:pass@host:5432/dbname
# Connection pool ceiling. Keep below the server's max_connections.
PG_POOL_MAX=10

# ─── AI providers ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-...                    # REQUIRED — LLM + embeddings
ELEVENLABS_API_KEY=...                   # REQUIRED — TTS
VAPI_API_KEY=...                         # REQUIRED — assistant sync, calls
VAPI_WEBHOOK_SECRET=...                  # REQUIRED — verifies inbound webhooks
VAPI_PHONE_NUMBER_ID=...                 # platform-wide fallback outbound number
# Public URL of THIS server, for the in-call knowledge-base tool callback.
# Railway sets RAILWAY_PUBLIC_DOMAIN automatically; override only if needed.
# PUBLIC_BASE_URL=https://your-app.up.railway.app

# ─── Tenant isolation ──────────────────────────────────────────────
# 1 = every query carries tenant context. Must be live BEFORE running
# scripts/rls-migrate.js, or policies would be on with no context set.
RLS_ENABLED=1

# ─── Observability ─────────────────────────────────────────────────
# REQUIRED to expose /metrics. Without it /metrics returns 503 in production
# rather than publishing route latency + heap internals to anyone who asks.
METRICS_TOKEN=generate-a-long-random-string
# SENTRY_DSN=https://...ingest.sentry.io/...
# LOG_LEVEL=info

# ─── PDPL / data protection ────────────────────────────────────────
# Field encryption for calls.caller_number and campaign_contacts.phone.
# 32 bytes as hex(64) or base64:  openssl rand -hex 32
#
#   !! DO NOT SET THIS UNTIL BACKUPS ARE VERIFIED.
#   Losing this key makes the encrypted columns permanently unreadable.
#   Reads tolerate both plaintext and ciphertext, so enabling it later is a
#   non-event — rows convert as they are next written.
# DATA_ENCRYPTION_KEY=

# Retention, in days. Unset/0 = keep forever (the safe default — nothing is
# ever deleted unless you opt in).
# RETENTION_DAYS_CALLS=365
# RETENTION_DAYS_CHATS=365
# RETENTION_DAYS_AUDIT=730
# RETENTION_DAYS_WEBHOOKS=30

# Phone-number masking in logs. On by default; set 0 only to debug.
# LOG_REDACT_PII=0

# ─── Background jobs ───────────────────────────────────────────────
# Without REDIS_URL, workers fall back to in-process timers, which means the
# app MUST stay at a single replica.
# REDIS_URL=redis://default:pass@host:6379

# ─── Voice / latency tuning ────────────────────────────────────────
# Endpointing wait when the transcriber emits no punctuation. With a
# non-streaming transcriber this fires on essentially every turn and is the
# single largest latency knob. Re-measure with scripts/profile-calls.js.
ENDPOINT_NOPUNCT_S=1.0
# ENDPOINT_PUNCT_S=0.1
# ENDPOINT_NUMBER_S=0.4
# Full Vapi transcriber object, for A/B testing STT providers.
# TRANSCRIBER_JSON={"provider":"google","model":"gemini-2.5-flash","language":"Arabic"}
# Extra ElevenLabs voice ids selectable in settings (comma-separated).
# EXTRA_VOICE_IDS=

# ─── Usage caps (cost circuit breaker) ─────────────────────────────
# Platform defaults. Per-company overrides are superadmin-only.
# DAILY_MSG_CAP=2000
# DAILY_OUTBOUND_CAP=200
# AGENT_RATE_PER_MIN=120

# ─── Offsite backups (configured separately) ───────────────────────
# BACKUP_S3_BUCKET=
# BACKUP_S3_ACCESS_KEY_ID=
# BACKUP_S3_SECRET_ACCESS_KEY=
# BACKUP_S3_ENDPOINT=
# BACKUP_INTERVAL_HOURS=24
# BACKUP_KEEP=14

# NOTE: Twilio was fully removed in July 2026. Telephony is
# landline -> 3CX PBX -> SIP trunk -> Vapi. Do not add TWILIO_* variables.
# NOTE: ELEVENLABS_VOICE_ID is ignored — the default voice is set in code
# (DEFAULT_VOICE_ID) so a stale env var cannot silently override it.
