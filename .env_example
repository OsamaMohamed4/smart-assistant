ELEVENLABS_VOICE_ID=...

# Twilio
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...
# WhatsApp sandbox / approved number — format: whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Until each company has its own WhatsApp number, every inbound message
# routes to this company. Set to the company id (e.g. co-xjdidl).
TWILIO_DEFAULT_COMPANY_ID=

# Vapi
VAPI_API_KEY=...
VAPI_PHONE_NUMBER_ID=...

# Server
PORT=3000
NODE_ENV=development

