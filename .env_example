# OpenAI
OPENAI_API_KEY=sk-...

# ElevenLabs
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=...

# Twilio
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...
# WhatsApp sandbox / approved number — format: whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Until each company has its own WhatsApp number, every inbound message
# routes to this company. Set to the company id (e.g. co-xjdidl).
TWILIO_DEFAULT_COMPANY_ID=

# Vapi
VAPI_API_KEY=...
VAPI_PHONE_NUMBER_ID=...

# Server
PORT=3000
NODE_ENV=development

PORT=
VAPI_WEBHOOK_SECRET=
TRUST_PROXY=
NODE_ENV=
VAPI_PUBLIC_KEY=

# LoopChat (Saudi WhatsApp BSP — sends approved templates).
# Leave LOOPCHAT_TEMPLATE_UUID_CALL_SUMMARY empty to disable the post-call
# WhatsApp notification entirely. When set, every Vapi call lasting >=30s
# triggers a template send to the customer's number with two body vars:
# {{1}} = company name, {{2}} = call summary.
LOOPCHAT_API_BASE_URL=https://api.loopchat.sa
LOOPCHAT_API_KEY=
LOOPCHAT_TEMPLATE_UUID_CALL_SUMMARY=